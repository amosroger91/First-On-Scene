{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://first-on-scene.io/schemas/findings_schema.json",
  "title": "First-On-Scene Analyzer Findings",
  "description": "Deterministic output of the First-On-Scene analyzer. Produced with ZERO AI and ZERO network egress. An optional local-only LLM narrative may be attached but never changes the verdict.",
  "type": "object",
  "required": ["caseId", "analyzedTimestampUtc", "engineVersion", "rulesetVersion", "verdict", "score", "classification", "findings"],
  "additionalProperties": true,
  "properties": {
    "caseId": { "type": "string" },
    "analyzedTimestampUtc": { "type": "string", "format": "date-time" },
    "engineVersion": { "type": "string" },
    "rulesetVersion": { "type": "string" },
    "targetHostname": { "type": "string" },
    "analyst": {
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "host": { "type": "string" }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["ALL_CLEAR", "MONITOR", "PROBLEM_DETECTED"],
      "description": "ALL_CLEAR -> exit 0. MONITOR -> exit 10. PROBLEM_DETECTED -> exit 20 (incident) or 21 (breach)."
    },
    "score": {
      "type": "integer",
      "description": "Weighted sum of matched rule weights."
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "classification": {
      "type": "string",
      "description": "Incident-management classification.",
      "enum": ["None", "Event", "Incident", "Breach"]
    },
    "reasonCode": {
      "type": "string",
      "description": "Capitalized concise code passed to the action script (e.g. RANSOMWARE_ENCRYPTED_FILES)."
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "monitor": { "type": "integer" },
        "problem": { "type": "integer" },
        "breach": { "type": "integer" }
      }
    },
    "summaryCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "name", "category", "severity", "weight"],
        "properties": {
          "ruleId": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "mitre": {
            "type": "object",
            "properties": {
              "tactic": { "type": "string" },
              "technique": { "type": "string" }
            }
          },
          "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
          "weight": { "type": "integer" },
          "rationale": { "type": "string" },
          "falsePositive": { "type": "string" },
          "evidence": {
            "type": "array",
            "description": "The artifact records that matched this rule.",
            "items": { "type": "object" }
          },
          "evidenceCount": { "type": "integer" }
        }
      }
    },
    "aiNarrative": {
      "type": "object",
      "description": "OPTIONAL. Present only if a local-only LLM (Ollama) was explicitly enabled. Advisory text only; never authoritative.",
      "properties": {
        "enabled": { "type": "boolean" },
        "model": { "type": "string" },
        "endpoint": { "type": "string", "description": "Must be a loopback/localhost endpoint." },
        "text": { "type": "string" }
      }
    }
  }
}
