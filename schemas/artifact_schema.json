{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://first-on-scene.io/schemas/artifact_schema.json",
  "title": "First-On-Scene Forensic Artifact Bundle",
  "description": "Contract for the evidence bundle emitted by a First-On-Scene collector (PowerShell or Bash). The collector is READ-ONLY and performs NO analysis. ALL fields are produced on the endpoint with zero network egress.",
  "type": "object",
  "required": ["metadata", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of this artifact schema (semver)."
    },
    "metadata": {
      "type": "object",
      "required": ["caseId", "collectionTimestampUtc", "targetHostname", "platform", "collectorVersion", "operator"],
      "additionalProperties": true,
      "properties": {
        "caseId": {
          "type": "string",
          "description": "Unique case identifier (e.g. FOS-20260619-HOSTNAME-ab12cd)."
        },
        "collectionTimestampUtc": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp when collection started."
        },
        "targetHostname": { "type": "string" },
        "platform": { "type": "string", "enum": ["windows", "linux", "darwin"] },
        "osVersion": { "type": "string" },
        "collectorVersion": { "type": "string" },
        "executionMode": { "type": "string", "enum": ["local", "remote"] },
        "evidenceIntegrityMode": {
          "type": "boolean",
          "description": "True when collection was strictly read-only (no rkill, no Defender toggling, no system modification). Default and recommended."
        },
        "expectedRemoteTools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Operator-declared sanctioned remote-access/RMM tools (allow-list). Tools found that do not match any entry are flagged."
        },
        "operator": {
          "type": "object",
          "description": "Identity of the person/system that performed collection (CJIS 5.4 accountability).",
          "required": ["user", "host"],
          "properties": {
            "user": { "type": "string" },
            "host": { "type": "string" },
            "tool": { "type": "string" }
          }
        },
        "timeRange": {
          "type": "object",
          "description": "Optional event-log collection window.",
          "properties": {
            "startUtc": { "type": "string", "format": "date-time" },
            "endUtc": { "type": "string", "format": "date-time" }
          }
        },
        "errors": {
          "type": "array",
          "description": "Non-fatal collection errors (a collector NEVER aborts on a single failed artifact).",
          "items": {
            "type": "object",
            "required": ["component", "message"],
            "properties": {
              "component": { "type": "string" },
              "message": { "type": "string" },
              "timestampUtc": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Normalized forensic artifacts. Field names here are the selectors referenced by rules/detections.json.",
      "additionalProperties": true,
      "properties": {
        "remoteAccess": {
          "type": "object",
          "description": "Remote-access / RMM software discovered on the host.",
          "properties": {
            "tools": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "tool": { "type": "string" },
                  "evidence": { "type": "string", "description": "process | service | installed" },
                  "detail": { "type": "string" },
                  "authorized": { "type": "boolean", "description": "True if it matched the operator's expected list." }
                }
              }
            }
          }
        },
        "securityPosture": {
          "type": "object",
          "description": "Security-product health and tamper state.",
          "properties": {
            "defender": {
              "type": "object",
              "properties": {
                "available": { "type": "boolean" },
                "realTimeEnabled": { "type": "boolean" },
                "antivirusEnabled": { "type": "boolean" },
                "tamperProtectionEnabled": { "type": "boolean" },
                "exclusionPaths": { "type": "array", "items": { "type": "string" } },
                "exclusionExtensions": { "type": "array", "items": { "type": "string" } },
                "exclusionProcesses": { "type": "array", "items": { "type": "string" } }
              }
            },
            "firewall": {
              "type": "object",
              "description": "Windows Firewall profile state (read-only).",
              "properties": {
                "available": { "type": "boolean" },
                "profiles": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string", "description": "Domain | Private | Public" },
                      "enabled": { "type": "boolean" },
                      "defaultInboundAction": { "type": "string" },
                      "defaultOutboundAction": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "accessControl": {
          "type": "object",
          "description": "Account and remote-access posture (context).",
          "properties": {
            "localAdmins": { "type": "array", "items": { "type": "string" } },
            "rdpEnabled": { "type": "boolean" },
            "shares": { "type": "array", "items": { "type": "string" } }
          }
        },
        "defenseEvasion": {
          "type": "object",
          "properties": {
            "logClearEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "log": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "registryRunKeys": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hive": { "type": "string" },
                  "keyPath": { "type": "string" },
                  "valueName": { "type": "string" },
                  "valueData": { "type": "string" }
                }
              }
            },
            "scheduledTasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "taskName": { "type": "string" },
                  "path": { "type": "string" },
                  "state": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "author": { "type": "string" },
                  "actions": { "type": "string" },
                  "triggers": { "type": "string" }
                }
              }
            },
            "services": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "displayName": { "type": "string" },
                  "state": { "type": "string" },
                  "startMode": { "type": "string" },
                  "pathName": { "type": "string" }
                }
              }
            },
            "wmiEventSubscriptions": {
              "type": "object",
              "properties": {
                "eventFilters": { "type": "array", "items": { "type": "object" } },
                "eventConsumers": { "type": "array", "items": { "type": "object" } },
                "filterBindings": { "type": "array", "items": { "type": "object" } }
              }
            },
            "asep": {
              "type": "array",
              "description": "Anomalous auto-start extensibility points (only deviations are recorded).",
              "items": {
                "type": "object",
                "properties": {
                  "category": { "type": "string", "description": "IFEO | AppInitDLLs | Winlogon | Accessibility" },
                  "location": { "type": "string" },
                  "name": { "type": "string" },
                  "value": { "type": "string" }
                }
              }
            },
            "cronJobs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "schedule": { "type": "string" },
                  "command": { "type": "string" }
                }
              }
            },
            "systemdServices": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "unit": { "type": "string" },
                  "state": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "execStart": { "type": "string" }
                }
              }
            },
            "autostartFiles": {
              "type": "array",
              "description": "Linux/macOS autostart entries (.desktop, LaunchDaemons, rc.local, etc.).",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "command": { "type": "string" }
                }
              }
            }
          }
        },
        "execution": {
          "type": "object",
          "properties": {
            "processes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "processId": { "type": "integer" },
                  "name": { "type": "string" },
                  "executablePath": { "type": "string" },
                  "commandLine": { "type": "string" },
                  "parentProcessId": { "type": "integer" },
                  "user": { "type": "string" },
                  "signatureStatus": { "type": "string", "description": "Valid | NotSigned | HashMismatch | UnknownError | NotApplicable" },
                  "signer": { "type": "string" },
                  "sha256": { "type": "string" },
                  "imageDeleted": { "type": "boolean", "description": "True if the process image path no longer exists on disk." }
                }
              }
            },
            "prefetch": {
              "type": "array",
              "description": "Prefetch entries (execution evidence; -Deep).",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "lastRunUtc": { "type": "string" }
                }
              }
            },
            "injectedModules": {
              "type": "array",
              "description": "Unsigned modules loaded into processes (possible injection; -Deep).",
              "items": {
                "type": "object",
                "properties": {
                  "process": { "type": "string" },
                  "module": { "type": "string" },
                  "signatureStatus": { "type": "string" }
                }
              }
            },
            "drivers": {
              "type": "array",
              "description": "Running kernel-mode drivers with Authenticode signature status (-Deep).",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "displayName": { "type": "string" },
                  "pathName": { "type": "string" },
                  "state": { "type": "string" },
                  "startMode": { "type": "string" },
                  "signatureStatus": { "type": "string", "description": "Valid | NotSigned | HashMismatch | ..." },
                  "signer": { "type": "string" }
                }
              }
            },
            "processCreationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "newProcessName": { "type": "string" },
                  "commandLine": { "type": "string" },
                  "parentProcessName": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          }
        },
        "network": {
          "type": "object",
          "properties": {
            "connections": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "protocol": { "type": "string" },
                  "localAddress": { "type": "string" },
                  "localPort": { "type": "integer" },
                  "remoteAddress": { "type": "string" },
                  "remotePort": { "type": "integer" },
                  "state": { "type": "string" },
                  "processId": { "type": "integer" },
                  "processName": { "type": "string" }
                }
              }
            },
            "listeners": {
              "type": "array",
              "description": "Listening TCP/UDP endpoints with owning process.",
              "items": {
                "type": "object",
                "properties": {
                  "protocol": { "type": "string", "description": "TCP | UDP" },
                  "localAddress": { "type": "string" },
                  "localPort": { "type": "integer" },
                  "processId": { "type": "integer" },
                  "processName": { "type": "string" }
                }
              }
            },
            "dnsCache": {
              "type": "array",
              "description": "Local DNS client cache (read-only; shows resolved names without any new lookup).",
              "items": {
                "type": "object",
                "properties": {
                  "entry": { "type": "string" },
                  "name": { "type": "string" },
                  "data": { "type": "string" },
                  "type": { "type": "string" },
                  "ttl": { "type": "integer" }
                }
              }
            },
            "hostsFileEntries": {
              "type": "array",
              "description": "Non-comment entries parsed from the hosts file.",
              "items": {
                "type": "object",
                "properties": {
                  "ipAddress": { "type": "string" },
                  "hostnames": { "type": "string" },
                  "raw": { "type": "string" }
                }
              }
            }
          }
        },
        "credentialAccess": {
          "type": "object",
          "properties": {
            "logonEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "logonType": { "type": "integer" },
                  "account": { "type": "string" },
                  "sourceAddress": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "privilegeEscalationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "user": { "type": "string" },
                  "privileges": { "type": "string" }
                }
              }
            },
            "userCreationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "serviceInstallEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "fileSystem": {
          "type": "object",
          "properties": {
            "fileMetadata": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string" },
                  "size": { "type": "integer" },
                  "permissions": { "type": "string" },
                  "uid": { "type": "integer" },
                  "gid": { "type": "integer" },
                  "modified": { "type": "string" },
                  "accessed": { "type": "string" },
                  "created": { "type": "string" }
                }
              }
            },
            "browserArtifacts": {
              "type": "array",
              "description": "Browser history databases SEALED as hashed evidence (copied verbatim into the case). The collector NEVER parses them on the endpoint; structured analysis is done off-box on the forensic clone.",
              "items": {
                "type": "object",
                "properties": {
                  "browser": { "type": "string", "description": "Chrome | Edge | Brave" },
                  "user": { "type": "string" },
                  "profile": { "type": "string", "description": "Default | Profile N" },
                  "artifact": { "type": "string", "description": "e.g. History" },
                  "sourcePath": { "type": "string" },
                  "sealedFile": { "type": "string", "description": "Filename of the hashed copy inside the case folder (covered by manifest.json)." },
                  "sha256": { "type": "string" },
                  "sizeBytes": { "type": "integer" },
                  "modifiedUtc": { "type": "string" }
                }
              }
            }
          }
        },
        "exfiltration": {
          "type": "object",
          "description": "Data-theft / data-movement signals (read-only). Ingress provenance, staging, and egress channels.",
          "properties": {
            "downloadProvenance": {
              "type": "array",
              "description": "Files carrying a Zone.Identifier (Mark-of-the-Web): the URL each was downloaded from.",
              "items": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string" },
                  "sourceUrl": { "type": "string", "description": "HostUrl from the Zone.Identifier ADS." },
                  "referrerUrl": { "type": "string" },
                  "sourceHost": { "type": "string", "description": "Hostname parsed from the source/referrer URL." },
                  "zoneId": { "type": "string" },
                  "sizeBytes": { "type": "integer" },
                  "modifiedUtc": { "type": "string" }
                }
              }
            },
            "archiveStaging": {
              "type": "array",
              "description": "Recently-written archives in user-writable/temp paths (possible collection before exfil).",
              "items": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string" },
                  "sizeBytes": { "type": "integer" },
                  "createdUtc": { "type": "string" },
                  "modifiedUtc": { "type": "string" },
                  "ageMinutes": { "type": "integer" }
                }
              }
            },
            "bitsJobs": {
              "type": "array",
              "description": "Background Intelligent Transfer Service jobs (a low-noise ingress/exfil channel).",
              "items": {
                "type": "object",
                "properties": {
                  "displayName": { "type": "string" },
                  "owner": { "type": "string" },
                  "state": { "type": "string" },
                  "transferType": { "type": "string" },
                  "remoteUrl": { "type": "string" },
                  "files": { "type": "array", "items": { "type": "object" } }
                }
              }
            },
            "transferTools": {
              "type": "array",
              "description": "Bulk data-egress utilities present (rclone, MEGAcmd, FileZilla, WinSCP, croc, etc.). Default Windows components are intentionally excluded.",
              "items": {
                "type": "object",
                "properties": {
                  "tool": { "type": "string" },
                  "evidence": { "type": "string", "description": "process | service | installed" },
                  "detail": { "type": "string" }
                }
              }
            },
            "remoteToolTransferLogs": {
              "type": "array",
              "description": "File-transfer log lines found in remote-access/RMM tool install directories.",
              "items": {
                "type": "object",
                "properties": {
                  "tool": { "type": "string" },
                  "logPath": { "type": "string" },
                  "lineCount": { "type": "integer" },
                  "matchedLines": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "powerShellActivity": {
          "type": "object",
          "properties": {
            "scriptBlockLogs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "timestamp": { "type": "string" },
                  "scriptBlock": { "type": "string" },
                  "path": { "type": "string" }
                }
              }
            }
          }
        },
        "antivirusScans": {
          "type": "object",
          "properties": {
            "defenderScan": {
              "type": "object",
              "properties": {
                "executed": { "type": "boolean" },
                "threatsFound": { "type": "integer" },
                "threats": { "type": "array", "items": { "type": "object" } }
              }
            },
            "clamavScan": {
              "type": "object",
              "properties": {
                "executed": { "type": "boolean" },
                "threatsFound": { "type": "integer" },
                "threats": { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    }
  }
}
