{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://first-on-scene.io/schemas/artifact_schema.json",
  "title": "First-On-Scene Forensic Artifact Bundle",
  "description": "Contract for the evidence bundle emitted by a First-On-Scene collector (PowerShell or Bash). The collector is READ-ONLY and performs NO analysis. ALL fields are produced on the endpoint with zero network egress.",
  "type": "object",
  "required": ["metadata", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of this artifact schema (semver)."
    },
    "metadata": {
      "type": "object",
      "required": ["caseId", "collectionTimestampUtc", "targetHostname", "platform", "collectorVersion", "operator"],
      "additionalProperties": true,
      "properties": {
        "caseId": {
          "type": "string",
          "description": "Unique case identifier (e.g. FOS-20260619-HOSTNAME-ab12cd)."
        },
        "collectionTimestampUtc": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp when collection started."
        },
        "targetHostname": { "type": "string" },
        "platform": { "type": "string", "enum": ["windows", "linux", "darwin"] },
        "osVersion": { "type": "string" },
        "collectorVersion": { "type": "string" },
        "executionMode": { "type": "string", "enum": ["local", "remote"] },
        "evidenceIntegrityMode": {
          "type": "boolean",
          "description": "True when collection was strictly read-only (no rkill, no Defender toggling, no system modification). Default and recommended."
        },
        "expectedRemoteTools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Operator-declared sanctioned remote-access/RMM tools (allow-list). Tools found that do not match any entry are flagged."
        },
        "operator": {
          "type": "object",
          "description": "Identity of the person/system that performed collection (CJIS 5.4 accountability).",
          "required": ["user", "host"],
          "properties": {
            "user": { "type": "string" },
            "host": { "type": "string" },
            "tool": { "type": "string" }
          }
        },
        "timeRange": {
          "type": "object",
          "description": "Optional event-log collection window.",
          "properties": {
            "startUtc": { "type": "string", "format": "date-time" },
            "endUtc": { "type": "string", "format": "date-time" }
          }
        },
        "errors": {
          "type": "array",
          "description": "Non-fatal collection errors (a collector NEVER aborts on a single failed artifact).",
          "items": {
            "type": "object",
            "required": ["component", "message"],
            "properties": {
              "component": { "type": "string" },
              "message": { "type": "string" },
              "timestampUtc": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Normalized forensic artifacts. Field names here are the selectors referenced by rules/detections.json.",
      "additionalProperties": true,
      "properties": {
        "remoteAccess": {
          "type": "object",
          "description": "Remote-access / RMM software discovered on the host.",
          "properties": {
            "tools": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "tool": { "type": "string" },
                  "evidence": { "type": "string", "description": "process | service | installed" },
                  "detail": { "type": "string" },
                  "authorized": { "type": "boolean", "description": "True if it matched the operator's expected list." }
                }
              }
            }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "registryRunKeys": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hive": { "type": "string" },
                  "keyPath": { "type": "string" },
                  "valueName": { "type": "string" },
                  "valueData": { "type": "string" }
                }
              }
            },
            "scheduledTasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "taskName": { "type": "string" },
                  "path": { "type": "string" },
                  "state": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "author": { "type": "string" },
                  "actions": { "type": "string" },
                  "triggers": { "type": "string" }
                }
              }
            },
            "services": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "displayName": { "type": "string" },
                  "state": { "type": "string" },
                  "startMode": { "type": "string" },
                  "pathName": { "type": "string" }
                }
              }
            },
            "wmiEventSubscriptions": {
              "type": "object",
              "properties": {
                "eventFilters": { "type": "array", "items": { "type": "object" } },
                "eventConsumers": { "type": "array", "items": { "type": "object" } },
                "filterBindings": { "type": "array", "items": { "type": "object" } }
              }
            },
            "cronJobs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "schedule": { "type": "string" },
                  "command": { "type": "string" }
                }
              }
            },
            "systemdServices": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "unit": { "type": "string" },
                  "state": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "execStart": { "type": "string" }
                }
              }
            },
            "autostartFiles": {
              "type": "array",
              "description": "Linux/macOS autostart entries (.desktop, LaunchDaemons, rc.local, etc.).",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "command": { "type": "string" }
                }
              }
            }
          }
        },
        "execution": {
          "type": "object",
          "properties": {
            "processes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "processId": { "type": "integer" },
                  "name": { "type": "string" },
                  "executablePath": { "type": "string" },
                  "commandLine": { "type": "string" },
                  "parentProcessId": { "type": "integer" },
                  "user": { "type": "string" }
                }
              }
            },
            "processCreationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "newProcessName": { "type": "string" },
                  "commandLine": { "type": "string" },
                  "parentProcessName": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          }
        },
        "network": {
          "type": "object",
          "properties": {
            "connections": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "protocol": { "type": "string" },
                  "localAddress": { "type": "string" },
                  "localPort": { "type": "integer" },
                  "remoteAddress": { "type": "string" },
                  "remotePort": { "type": "integer" },
                  "state": { "type": "string" },
                  "processId": { "type": "integer" },
                  "processName": { "type": "string" }
                }
              }
            }
          }
        },
        "credentialAccess": {
          "type": "object",
          "properties": {
            "logonEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "logonType": { "type": "integer" },
                  "account": { "type": "string" },
                  "sourceAddress": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "privilegeEscalationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "user": { "type": "string" },
                  "privileges": { "type": "string" }
                }
              }
            },
            "userCreationEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "serviceInstallEvents": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eventId": { "type": "integer" },
                  "timestamp": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "fileSystem": {
          "type": "object",
          "properties": {
            "fileMetadata": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string" },
                  "size": { "type": "integer" },
                  "permissions": { "type": "string" },
                  "uid": { "type": "integer" },
                  "gid": { "type": "integer" },
                  "modified": { "type": "string" },
                  "accessed": { "type": "string" },
                  "created": { "type": "string" }
                }
              }
            },
            "browserArtifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": { "path": { "type": "string" } }
              }
            }
          }
        },
        "powerShellActivity": {
          "type": "object",
          "properties": {
            "scriptBlockLogs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "timestamp": { "type": "string" },
                  "scriptBlock": { "type": "string" },
                  "path": { "type": "string" }
                }
              }
            }
          }
        },
        "antivirusScans": {
          "type": "object",
          "properties": {
            "defenderScan": {
              "type": "object",
              "properties": {
                "executed": { "type": "boolean" },
                "threatsFound": { "type": "integer" },
                "threats": { "type": "array", "items": { "type": "object" } }
              }
            },
            "clamavScan": {
              "type": "object",
              "properties": {
                "executed": { "type": "boolean" },
                "threatsFound": { "type": "integer" },
                "threats": { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    }
  }
}
